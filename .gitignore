# =============================================================================
# ecomm — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
build/
out/
cmake-build-*/          # CLion default build directories
install/

# CMake generated files at the source root (in-source builds — discouraged)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_deps/

# Ninja / Make artefacts
*.ninja
*.make
Makefile

# Compiled object and library files
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.out
*.app

# -----------------------------------------------------------------------------
# C++ generated / transient files
# -----------------------------------------------------------------------------

# Precompiled headers
*.gch
*.pch

# Dependency tracking files emitted by some compilers
*.d

# Address-sanitizer / UB-sanitizer suppressions generated at runtime
*.asan
*.ubsan

# Coverage data
*.gcno
*.gcda
*.gcov
lcov.info
coverage/

# Profiling
gmon.out
*.prof

# Core dumps
core
core.*
vgcore.*

# -----------------------------------------------------------------------------
# IDE / editor artefacts
# -----------------------------------------------------------------------------

# VS Code (keep .vscode/settings.json if you version it; ignore generated ones)
.vscode/
*.code-workspace

# CLion
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.neoconf.json

# Emacs
\#*\#
.\#*
*.elc
auto-save-list/
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Toolchain / static analysis output
# -----------------------------------------------------------------------------
compile_commands.json    # Generated by CMake; useful locally but not versioned
.cache/                  # clangd index, ccache, etc.
.clangd/
ccls-cache/

# Doxygen output
docs/html/
docs/latex/
docs/xml/
Doxyfile.bak

# cppcheck
cppcheck-result.xml

# valgrind
*.memcheck

# -----------------------------------------------------------------------------
# Dependency manager caches (if ever used)
# -----------------------------------------------------------------------------
.conan/
.vcpkg/
vcpkg_installed/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

# Patch / diff files
*.patch
*.diff
*.orig
*.rej

# Archives
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Log files
*.log

# -----------------------------------------------------------------------------
# ecomm-python (uv / Python)
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.egg-info/
ecomm-python/dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
